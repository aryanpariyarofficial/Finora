# Supabase — copy this file to .env.local and fill in from
# https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never exposed to the browser).
# Required for the daily reminder cron (/api/cron/reminders).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email (Resend — https://resend.com). Sender domain must be verified
# in Resend to email arbitrary recipients.
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM="Finora <finora@yourdomain.com>"
EMAIL_REPLY_TO=you@example.com
# Where admin alerts (new upgrade requests) are sent.
ADMIN_EMAIL=you@example.com

# Protects /api/cron/reminders. Vercel Cron sends it automatically
# when this env var is set in the Vercel project.
CRON_SECRET=generate-a-long-random-string
